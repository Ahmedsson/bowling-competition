<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tävlingsanmälan - Bowling</title>
    <link rel="stylesheet" href="css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <!-- LOGIN SCREEN -->
    <div id="login-screen" class="screen active">
        <div class="login-background">
            <div class="floating-pins">
                <span>🎳</span><span>🎳</span><span>🎳</span>
                <span>🏆</span><span>🎳</span><span>🏆</span>
            </div>
        </div>
        <div class="login-container">
            <div class="login-card">
                <div class="login-header">
                    <div class="logo-icon">🎳</div>
                    <h1>Tävlingsportalen</h1>
                    <p>Anmäl dig till bowlingtävlingar</p>
                </div>
                <div class="login-buttons">
                    <button class="login-btn google-btn" onclick="loginWith('google')">
                        <svg viewBox="0 0 24 24" width="24" height="24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span>Logga in med Google</span>
                    </button>
                    <button class="login-btn microsoft-btn" onclick="loginWith('microsoft')">
                        <svg viewBox="0 0 24 24" width="24" height="24">
                            <rect fill="#F25022" x="1" y="1" width="10" height="10"/>
                            <rect fill="#7FBA00" x="13" y="1" width="10" height="10"/>
                            <rect fill="#00A4EF" x="1" y="13" width="10" height="10"/>
                            <rect fill="#FFB900" x="13" y="13" width="10" height="10"/>
                        </svg>
                        <span>Logga in med Microsoft</span>
                    </button>
                    <button class="login-btn apple-btn" onclick="loginWith('apple')">
                        <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
                            <path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                        </svg>
                        <span>Logga in med Apple</span>
                    </button>
                </div>
                <div class="login-footer">
                    <p>Genom att logga in godkänner du våra <a href="#">villkor</a></p>
                </div>
            </div>
        </div>
    </div>

    <!-- COMPETITIONS LIST SCREEN -->
    <div id="competitions-screen" class="screen">
        <nav class="navbar">
            <div class="nav-brand">
                <span class="nav-logo">🎳</span>
                <span class="nav-title">Tävlingsportalen</span>
            </div>
            <div class="nav-user">
                <div class="user-info">
                    <img id="user-avatar" src="" alt="Avatar" class="user-avatar">
                    <span id="user-name" class="user-name"></span>
                </div>
                <button class="logout-btn" onclick="logout()">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logga ut</span>
                </button>
            </div>
        </nav>
        <main class="main-content">
            <div class="page-header">
                <h1>Kommande tävlingar</h1>
                <p>Välj en tävling att anmäla dig till</p>
                <div class="filter-bar">
                    <button class="filter-btn active" onclick="filterCompetitions('all', this)">Alla</button>
                    <button class="filter-btn" onclick="filterCompetitions('open', this)">Öppna</button>
                    <button class="filter-btn" onclick="filterCompetitions('closing-soon', this)">Stänger snart</button>
                    <button class="filter-btn" onclick="filterCompetitions('registered', this)">Mina anmälningar</button>
                </div>
            </div>
            <div id="competitions-grid" class="competitions-grid"></div>
        </main>
    </div>

    <!-- REGISTRATION FORM SCREEN -->
    <div id="registration-screen" class="screen">
        <nav class="navbar">
            <div class="nav-brand">
                <button class="back-btn" onclick="showScreen('competitions-screen')">
                    <i class="fas fa-arrow-left"></i>
                </button>
                <span class="nav-title" id="reg-comp-title">Anmälan</span>
            </div>
            <div class="nav-user">
                <div class="user-info">
                    <img id="user-avatar-2" src="" alt="Avatar" class="user-avatar">
                    <span id="user-name-2" class="user-name"></span>
                </div>
            </div>
        </nav>
        <main class="main-content">
            <div class="registration-layout">
                <div class="comp-info-panel">
                    <div class="comp-info-card">
                        <div class="comp-info-badge" id="reg-comp-badge">Tävling</div>
                        <h2 id="reg-comp-name"></h2>
                        <div class="comp-info-details">
                            <div class="info-row"><i class="fas fa-calendar-alt"></i><span id="reg-comp-date"></span></div>
                            <div class="info-row"><i class="fas fa-map-marker-alt"></i><span id="reg-comp-location"></span></div>
                            <div class="info-row"><i class="fas fa-clock"></i><span id="reg-comp-deadline"></span></div>
                            <div class="info-row"><i class="fas fa-money-bill-wave"></i><span id="reg-comp-fee"></span></div>
                            <div class="info-row"><i class="fas fa-users"></i><span id="reg-comp-spots"></span></div>
                        </div>
                        <div class="comp-description" id="reg-comp-description"></div>
                    </div>
                </div>
                <div class="registration-form-container">
                    <form id="registration-form" onsubmit="submitRegistration(event)">
                        <div class="form-section">
                            <h3><i class="fas fa-search"></i> Hämta spelaruppgifter</h3>
                            <p class="form-section-desc">Sök efter din spelarinformation från Svenska Bowlingförbundet</p>
                            <div class="swebowl-search">
                                <div class="form-group">
                                    <label for="license-number">Licensnummer / Namn</label>
                                    <div class="search-input-group">
                                        <input type="text" id="license-number" placeholder="Ange licensnummer eller namn...">
                                        <button type="button" class="search-btn" onclick="searchPlayer()">
                                            <i class="fas fa-search"></i>
                                            <span>Sök</span>
                                        </button>
                                    </div>
                                </div>
                                <div id="search-results" class="search-results hidden"></div>
                                <div id="player-info-card" class="player-info-card hidden">
                                    <div class="player-info-header">
                                        <i class="fas fa-check-circle"></i>
                                        <span>Spelaruppgifter hämtade</span>
                                    </div>
                                    <div class="player-info-grid">
                                        <div class="player-info-item"><label>Namn</label><span id="player-display-name"></span></div>
                                        <div class="player-info-item"><label>Förening</label><span id="player-display-club"></span></div>
                                        <div class="player-info-item"><label>Licensnr</label><span id="player-display-license"></span></div>
                                        <div class="player-info-item"><label>HCP</label><span id="player-display-hcp"></span></div>
                                        <div class="player-info-item"><label>Medelpoäng</label><span id="player-display-avg"></span></div>
                                        <div class="player-info-item"><label>Klass</label><span id="player-display-class"></span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-section">
                            <h3><i class="fas fa-user"></i> Personuppgifter</h3>
                            <div class="form-grid">
                                <div class="form-group"><label for="first-name">Förnamn *</label><input type="text" id="first-name" required></div>
                                <div class="form-group"><label for="last-name">Efternamn *</label><input type="text" id="last-name" required></div>
                                <div class="form-group"><label for="email">E-post *</label><input type="email" id="email" required></div>
                                <div class="form-group"><label for="phone">Telefon *</label><input type="tel" id="phone" required></div>
                                <div class="form-group"><label for="club">Förening</label><input type="text" id="club"></div>
                                <div class="form-group"><label for="license-nr">Licensnummer</label><input type="text" id="license-nr" readonly></div>
                            </div>
                        </div>
                        <div class="form-section">
                            <h3><i class="fas fa-bowling-ball"></i> Tävlingsinformation</h3>
                            <div class="form-grid">
                                <div class="form-group"><label for="hcp">Handikapp (HCP)</label><input type="number" id="hcp" readonly></div>
                                <div class="form-group"><label for="average">Medelpoäng</label><input type="number" id="average" readonly></div>
                                <div class="form-group">
                                    <label for="player-class">Klass</label>
                                    <select id="player-class">
                                        <option value="">Välj klass</option>
                                        <option value="A">A</option>
                                        <option value="B">B</option>
                                        <option value="C">C</option>
                                        <option value="D">D</option>
                                        <option value="damer">Damer</option>
                                        <option value="herrar">Herrar</option>
                                        <option value="ungdom">Ungdom</option>
                                        <option value="senior">Senior</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="preferred-time">Önskad spelomgång</label>
                                    <select id="preferred-time">
                                        <option value="">Ingen preferens</option>
                                        <option value="fm">Förmiddag</option>
                                        <option value="em">Eftermiddag</option>
                                        <option value="kvall">Kväll</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group full-width">
                                <label for="comments">Kommentarer / Övrigt</label>
                                <textarea id="comments" rows="3" placeholder="Eventuella önskemål eller kommentarer..."></textarea>
                            </div>
                        </div>
                        <div class="form-section">
                            <div class="form-checkbox">
                                <input type="checkbox" id="terms" required>
                                <label for="terms">Jag godkänner <a href="#">tävlingsvillkoren</a> och att mina uppgifter sparas *</label>
                            </div>
                            <div class="form-checkbox">
                                <input type="checkbox" id="gdpr" required>
                                <label for="gdpr">Jag samtycker till hantering av personuppgifter enligt <a href="#">GDPR</a> *</label>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="button" class="btn-secondary" onclick="showScreen('competitions-screen')">
                                <i class="fas fa-times"></i> Avbryt
                            </button>
                            <button type="submit" class="btn-primary">
                                <i class="fas fa-paper-plane"></i> Skicka anmälan
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <!-- SUCCESS MODAL -->
    <div id="success-modal" class="modal hidden">
        <div class="modal-overlay" onclick="closeModal()"></div>
        <div class="modal-content">
            <div class="modal-icon success"><i class="fas fa-check"></i></div>
            <h2>Anmälan skickad!</h2>
            <p>Din anmälan har registrerats. Du kommer att få en bekräftelse via e-post.</p>
            <div class="modal-details" id="modal-details"></div>
            <button class="btn-primary" onclick="closeModal(); showScreen('competitions-screen');">
                <i class="fas fa-arrow-left"></i> Tillbaka till tävlingar
            </button>
        </div>
    </div>

    <!-- LOADING OVERLAY -->
    <div id="loading-overlay" class="loading-overlay hidden">
        <div class="loader">
            <div class="bowling-ball"></div>
            <p>Laddar...</p>
        </div>
    </div>

    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    <script src="js/app.js"></script>
</body>
</html>
